{
  "dashboard": {
    "title": "API Overview",
    "uid": "api-overview",
    "tags": ["api", "overview"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(aws_applicationelb_request_count_sum[5m]))",
            "legendFormat": "Requests/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Response Time (p95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(aws_applicationelb_target_response_time_sum[5m])))",
            "legendFormat": "p95"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Error Rate (5xx)",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(aws_applicationelb_http_code_elb_5XX[5m])) / sum(rate(aws_applicationelb_request_count[5m])) * 100",
            "legendFormat": "5xx Error Rate %"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Error Rate (4xx)",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(aws_applicationelb_http_code_elb_4XX[5m])) / sum(rate(aws_applicationelb_request_count[5m])) * 100",
            "legendFormat": "4xx Error Rate %"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 5,
        "title": "CPU Utilization",
        "type": "graph",
        "targets": [
          {
            "expr": "avg(aws_ecs_containerinsights_cpu_utilization_average)",
            "legendFormat": "CPU %"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 6,
        "title": "Memory Utilization",
        "type": "graph",
        "targets": [
          {
            "expr": "avg(aws_ecs_containerinsights_memory_utilization_average)",
            "legendFormat": "Memory %"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 7,
        "title": "Active Tasks",
        "type": "stat",
        "targets": [
          {
            "expr": "count(aws_ecs_containerinsights_running_task_count)",
            "legendFormat": "Active Tasks"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24}
      },
      {
        "id": 8,
        "title": "Health Check Status",
        "type": "stat",
        "targets": [
          {
            "expr": "aws_ecs_containerinsights_cpu_utilization_average",
            "legendFormat": "Healthy"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 24}
      }
    ]
  }
}
