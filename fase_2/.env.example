# Configurações de Ambiente para o Pipeline do MLflow / DVC
MLFLOW_TRACKING_URI=https://mlflow.asgardprint.com.br
AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1
AWS_PROFILE=aws

# API Configuration
# Generate a strong API key using: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Security Configuration
# Rate limiting (e.g., "100/minute", "1000/hour")
RATE_LIMIT=100/minute

# IP Whitelisting (comma-separated list of allowed IPs, leave empty to disable)
# Example: ALLOWED_IPS=192.168.1.100,10.0.0.50
ALLOWED_IPS=

# Model Configuration
# MLflow URIs for model loading (tried in order, comma-separated)
# First tries remote AWS MLflow, then local MLflow server, then falls back to local file
MLFLOW_TRACKING_URIS=https://mlflow.asgardprint.com.br,http://mlflow:5000
MODEL_PATH=ecommerce_recommender/models/mlflow_experiments/gmf_binary.pt
MLFLOW_MODEL_NAME=
MLFLOW_MODEL_VERSION=
MLFLOW_MODEL_ALIAS=champion
