      "name": "predict sem o gender",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "",
              "pm.test(\"Status code is 422\", function () {",
              "    pm.response.to.have.status(422);",
              "});",
              "",
              "pm.test(\"Response body has a 'detail' field that is an array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"detail\");",
              "    pm.expect(jsonData.detail).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"'detail' array is not empty\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.detail).to.have.length.above(0);",
              "});",
              "",
              "pm.test(\"At least one error references the 'gender' field\", function () {",
              "    var jsonData = pm.response.json();",
              "    var hasGender = jsonData.detail.some(function (item) {",
              "        return Array.isArray(item.loc) && item.loc.indexOf(\"gender\") !== -1;",
              "    });",
              "    pm.expect(hasGender).to.be.true;",
              "});",
              "",
              "pm.test(\"Each error item has 'type', 'loc', and 'msg' fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    jsonData.detail.forEach(function (item) {",
              "        pm.expect(item).to.have.property(\"type\");",
              "        pm.expect(item).to.have.property(\"loc\");",
              "        pm.expect(item).to.have.property(\"msg\");",
              "    });",
              "});",
              "",
              "pm.test(\"Response time is under 3000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});",
