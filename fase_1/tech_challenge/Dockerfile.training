# Training Container - Executa base_pipeline.py e registra modelos no MLflow
# Versão: Python 3.12-slim com dependências de ML
# Roda: python src/models/base_pipeline.py

FROM python:3.12-slim

WORKDIR /app

# Instalar sistema deps necessários
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Copiar requirements (será criado/consolidado)
COPY pyproject.toml ./

# Instalar dependências com pip (simples, robusto, sem uv)
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir -e . && \
    pip install --no-cache-dir \
        mlflow \
        psycopg2-binary \
        scikit-learn \
        pandas \
        numpy \
        torch \
        pydantic

# Copiar código-fonte
COPY src ./src
COPY data ./data

# Variáveis de ambiente
ENV MLFLOW_TRACKING_URI=http://mlflow:5000
ENV PYTHONUNBUFFERED=1

# Comando padrão: executar pipeline de treinamento
# Pode ser sobrescrito com: docker-compose run training python src/models/baseline.py
CMD ["python", "src/models/base_pipeline.py"]
